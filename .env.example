# API 키 — 각 서비스에서 발급
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
OPENAI_API_KEY=sk-...

# Obsidian wiki 절대 경로 (NEVER commit 실제 값)
OBSIDIAN_WIKI_PATH=/Users/<your-username>/Documents/wiki

# Obsidian vault 이름 (인용 칩 클릭 시 Obsidian 으로 여는 데 필요)
# Obsidian 좌측 하단 vault 이름과 동일하게 박아야 함
OBSIDIAN_VAULT_NAME=wiki
